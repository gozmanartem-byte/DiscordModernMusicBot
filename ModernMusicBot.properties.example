# Copy this file to application.properties and fill your values.
# Never commit application.properties with a real token.

bot.token=PASTE_BOT_TOKEN_HERE
bot.prefix=!
# Bot language for Discord status/player
bot.language=en
# Control panel UI language
app.language=en
bot.dashboard.enabled=true
bot.dashboard.port=8090

# Optional: YouTube anti-bot fields (leave empty if not needed)
youtube.poToken=
youtube.visitorData=
